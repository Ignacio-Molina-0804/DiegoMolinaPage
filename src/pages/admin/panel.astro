---
import AdminLayout from "../../layouts/AdminLayout.astro";
import CartIcon from "../../components/icons/CartIcon.astro";
import UserIcon from "../../components/icons/UserIcon.astro";
import BoxIcon from "../../components/icons/BoxIcon.astro";
import TrashIcon from "../../components/icons/TrashIcon.astro";
import PencilIcon from "../../components/icons/PencilIcon.astro";
import EyeIcon from "../../components/icons/EyeIcon.astro";
---

<AdminLayout>
  <!-- Pantalla de Login -->
  <div
    id="auth-overlay"
    class="fixed inset-0 bg-[#000000] z-50 flex items-center justify-center backdrop-blur-sm"
  >
    <div
      class="bg-[#15011c] p-8 rounded-xl border border-[#00ff7f]/20 shadow-[0_0_20px_rgba(0,255,127,0.15)] w-full max-w-sm text-center transform transition-all relative"
    >
      <a href="/" class="absolute top-4 left-4 text-white/40 hover:text-white transition-colors" title="Volver al inicio">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <h2 class="text-2xl font-bold mb-2 text-[#00ff7f]">Acceso Restringido</h2>
      <p class="text-sm text-white/60 mb-6">Panel de control de ventas</p>

      <form id="login-form">
        <input
          type="password"
          id="auth-pass"
          class="w-full bg-[#1b0123] border border-white/10 rounded-lg px-4 py-3 mb-4 text-white focus:border-[#00ff7f] outline-none transition"
          placeholder="Contraseña de administrador"
          required
        />
        <button
          type="submit"
          class="w-full bg-[#00ff7f] text-black font-bold py-3 rounded-lg hover:brightness-110 shadow-[0_0_10px_rgba(0,255,127,0.3)] transition transform hover:scale-[1.02]"
          >Ingresar</button
        >
      </form>
      <p id="auth-error" class="text-red-400 text-sm mt-3 hidden">
        Contraseña incorrecta
      </p>
    </div>
  </div>

  <!-- Modal Detalles -->
  <div
    id="detalle-overlay"
    class="fixed inset-0 bg-[#000000]/80 z-50 hidden items-center justify-center backdrop-blur-sm"
  >
    <div
      class="bg-[#15011c] p-6 rounded-xl border border-white/10 shadow-[0_0_20px_rgba(0,0,0,0.5)] w-full max-w-md relative transform scale-95 transition-transform duration-200"
    >
      <button
        onclick="document.getElementById('detalle-overlay').classList.remove('flex'); document.getElementById('detalle-overlay').classList.add('hidden');"
        class="absolute top-4 right-4 text-white/50 hover:text-white text-xl"
        >✕</button
      >
      <h3 class="text-xl font-bold mb-4 text-[#00ff7f] flex items-center gap-2">
        <CartIcon class="w-6 h-6" /> Detalle de Venta
      </h3>
      <div
        id="detalle-content"
        class="space-y-2 text-white/80 max-h-60 overflow-y-auto pr-2 custom-scrollbar"
      >
      </div>
    </div>
  </div>
  <!-- Modal Detalles -->
  <div id="icon-templates" class="hidden">
    <div id="tpl-pencil"><PencilIcon class="w-4 h-4" /></div>
    <div id="tpl-trash"><TrashIcon class="w-4 h-4" /></div>
    <div id="tpl-eye"><EyeIcon class="w-4 h-4" /></div>
  </div>

  <!-- Dashboard Principal -->
  <div
    id="dashboard"
    class="w-full max-w-6xl mx-auto hidden flex-col h-[calc(100vh-3rem)]"
  >
    <!-- Cabecera del Dashboard -->
    <header
      class="flex flex-col sm:flex-row justify-between items-center mb-6 bg-[#15011c]/80 p-4 rounded-xl border border-white/10 backdrop-blur-md shadow-lg gap-4"
    >
      <div class="flex items-center gap-4">
        <a href="/" class="text-white/40 hover:text-white transition-colors flex items-center justify-center bg-white/5 hover:bg-white/10 p-2 rounded-lg" title="Volver al Inicio">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </a>
        <h1 class="text-[#00ff7f] font-bold text-xl uppercase tracking-wider">
          Control Panel
        </h1>
      </div>

      <div class="flex flex-wrap gap-2 justify-center">
        <button
          data-target="tab-ventas"
          class="tab-btn active px-4 py-2 rounded-lg bg-[#00ff7f] text-black font-bold text-sm shadow-[0_0_10px_rgba(0,255,127,0.2)] transition"
          >Ventas</button
        >
        <button
          data-target="tab-clientes"
          class="tab-btn px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 text-white font-medium text-sm transition"
          >Clientes</button
        >
        <button
          data-target="tab-products"
          class="tab-btn px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 text-white font-medium text-sm transition"
          >Productos</button
        >
        <button
          id="btn-logout"
          class="ml-2 px-4 py-2 rounded-lg border border-red-500/50 text-red-400 hover:bg-red-500/10 font-medium text-sm transition"
          >Salir</button
        >
      </div>
    </header>

    <!-- Contenedor Pestañas -->
    <div class="flex-grow overflow-y-auto pb-8">
      <!--==================== TAB VENTAS ====================-->
      <section id="tab-ventas" class="tab-content block space-y-6">
        <div
          class="bg-[#15011c]/60 border border-white/10 rounded-xl p-6 shadow-lg"
        >
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <CartIcon class="text-[#00ff7f] w-6 h-6" /> Registrar Nueva Venta
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
            <div class="md:col-span-12 mb-2 border-b border-white/10 pb-4">
              <label class="block text-xs text-white/50 mb-1"
                >Seleccionar Cliente</label
              >
              <select
                id="v-cliente"
                class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none appearance-none"
              >
                <option value="" disabled selected>Seleccione cliente...</option
                >
              </select>
            </div>
            <div class="md:col-span-6">
              <label class="block text-xs text-white/50 mb-1"
                >Añadir Producto</label
              >
              <select
                id="v-producto"
                class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none appearance-none"
              >
                <option value="" disabled selected
                  >Seleccione producto...</option
                >
              </select>
            </div>
            <div class="md:col-span-2">
              <label class="block text-xs text-white/50 mb-1">Cantidad</label>
              <input
                type="number"
                min="1"
                value="1"
                id="v-cantidad"
                class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none"
              />
            </div>
            <div class="md:col-span-4 flex items-end">
              <button
                type="button"
                id="btn-add-carrito"
                class="w-full bg-white/10 text-white font-bold py-3 rounded-lg hover:bg-white/20 transition"
                >+ Agregar al pedido</button
              >
            </div>
          </div>

          <div
            id="carrito-container"
            class="mt-6 hidden bg-black/20 rounded-lg p-4 border border-white/5"
          >
            <h3
              class="text-sm font-bold text-white/70 mb-3 uppercase tracking-wider"
            >
              Productos en esta venta
            </h3>
            <ul id="lista-carrito" class="space-y-2 mb-4"></ul>
            <div class="border-t border-white/10 pt-4 mt-4 space-y-4">
              <div class="flex justify-end items-center gap-4">
                <label for="v-envio" class="text-white/60 text-sm font-medium">Costo de Envío ($):</label>
                <input
                  type="number"
                  id="v-envio"
                  class="bg-[#1b0123] border border-white/10 rounded-lg px-3 py-1.5 text-white focus:border-[#00ff7f] outline-none w-32 transition font-mono"
                  placeholder="0"
                  min="0"
                  step="1"
                />
              </div>
              <div class="flex flex-col sm:flex-row justify-between items-center border-t border-white/5 pt-4 gap-4">
                <span class="text-xl text-white/50 font-bold"
                  >Total Final: <span id="carrito-total" class="text-[#00ff7f]"
                    >$0.00</span
                  ></span
                >
                <button
                  type="button"
                  id="btn-finalizar-venta"
                  class="bg-[#00ff7f] text-black font-bold px-6 py-2 rounded-lg hover:brightness-110 shadow-[0_0_10px_rgba(0,255,127,0.2)] transition w-full sm:w-auto"
                  >Confirmar Venta</button
                >
              </div>
            </div>
          </div>
        </div>

        <div
          class="bg-[#15011c]/60 border border-white/10 rounded-xl overflow-hidden shadow-lg"
        >
          <div
            class="p-4 bg-white/5 border-b border-white/10 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4"
          >
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 w-full sm:w-auto">
              <h3 class="font-bold whitespace-nowrap">Últimas Ventas</h3>
              <input
                type="text"
                id="filtro-ventas-cliente"
                placeholder="Buscar por cliente..."
                class="bg-[#1b0123] border border-white/10 rounded-lg px-3 py-1.5 text-sm text-white focus:border-[#00ff7f] outline-none w-full sm:w-64 transition"
              />
            </div>
            <span id="total-revenue" class="text-[#00ff7f] font-mono font-bold"
              >$0.00</span
            >
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead class="bg-black/40 text-white/60">
                <tr>
                  <th class="p-4 font-semibold">Fecha</th>
                  <th class="p-4 font-semibold">Cliente</th>
                  <th class="p-4 font-semibold">Detalle</th>
                  <th class="p-4 font-semibold text-right">Total</th>
                  <th class="p-4 w-10"></th>
                </tr>
              </thead>
              <tbody id="lista-ventas" class="divide-y divide-white/5">
                <tr
                  ><td colspan="5" class="p-4 text-center text-white/40"
                    >Cargando ventas...</td
                  ></tr
                >
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!--==================== TAB CLIENTES ====================-->
      <section id="tab-clientes" class="tab-content hidden space-y-6">
        <div
          class="bg-[#15011c]/60 border border-white/10 rounded-xl p-6 shadow-lg"
        >
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <UserIcon class="text-[#00ff7f] w-6 h-6" /> Agregar Cliente
          </h2>
          <form id="form-cliente" class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <input
              required
              type="text"
              id="c-nombre"
              placeholder="Nombre completo"
              class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none"
            />
            <input
              type="text"
              id="c-tel"
              placeholder="Teléfono"
              class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none"
            />
            <div class="flex gap-2">
              <input
                type="text"
                id="c-domicilio"
                placeholder="Domicilio"
                class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none"
              />
              <button
                type="submit"
                class="bg-white/10 text-white px-6 rounded-lg font-bold hover:bg-[#00ff7f] hover:text-black transition"
                >Guardar</button
              >
            </div>
          </form>
        </div>

        <div
          class="bg-[#15011c]/60 border border-white/10 rounded-xl overflow-hidden shadow-lg"
        >
          <table class="w-full text-left text-sm">
            <thead class="bg-black/40 text-white/60">
              <tr>
                <th class="p-4 font-semibold">Nombre</th>
                <th class="p-4 font-semibold">Teléfono</th>
                <th class="p-4 font-semibold">Domicilio</th>
                <th class="p-4 w-10"></th>
              </tr>
            </thead>
            <tbody id="lista-clientes" class="divide-y divide-white/5"></tbody>
          </table>
        </div>
      </section>

      <!--==================== TAB PRODUCTOS ====================-->
      <section id="tab-products" class="tab-content hidden space-y-6">
        <div
          class="bg-[#15011c]/60 border border-white/10 rounded-xl p-6 shadow-lg"
        >
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <BoxIcon class="text-[#00ff7f] w-6 h-6" /> Agregar Producto
          </h2>
          <form
            id="form-producto"
            class="grid grid-cols-1 md:grid-cols-12 gap-4"
          >
            <div class="md:col-span-5">
              <input
                required
                type="text"
                id="p-nombre"
                placeholder="Nombre del producto o servicio"
                class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none"
              />
            </div>
            <div class="md:col-span-3">
              <input
                required
                type="text"
                id="p-tipo"
                placeholder="Tipo (ej. Digital, Físico)"
                class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none"
              />
            </div>
            <div class="md:col-span-2">
              <input
                required
                type="number"
                step="0.01"
                id="p-precio"
                placeholder="Precio ($)"
                class="w-full bg-[#1b0123] border border-white/10 rounded-lg p-3 text-white focus:border-[#00ff7f] outline-none"
              />
            </div>
            <div class="md:col-span-2 flex items-end">
              <button
                type="submit"
                class="w-full bg-white/10 text-white py-3 rounded-lg font-bold hover:bg-[#00ff7f] hover:text-black transition"
                >Guardar</button
              >
            </div>
          </form>
        </div>

        <div
          class="bg-[#15011c]/60 border border-white/10 rounded-xl overflow-hidden shadow-lg"
        >
          <table class="w-full text-left text-sm">
            <thead class="bg-black/40 text-white/60">
              <tr>
                <th class="p-4 font-semibold">Nombre</th>
                <th class="p-4 font-semibold">Tipo</th>
                <th class="p-4 font-semibold">Precio / U.</th>
                <th class="p-4 w-10"></th>
              </tr>
            </thead>
            <tbody id="lista-productos" class="divide-y divide-white/5"></tbody>
          </table>
        </div>
      </section>
    </div>
  </div>

  <script src="../../scripts/adminPanel.ts"></script>
</AdminLayout>
