---
import "../styles/global.css";
import "@fontsource/poppins";

const siteUrl = "https://diegomolina.ar";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Panel de Administración | Control de Ventas</title>
    
    <!-- Favicons -->
    <link rel="icon" href="/logos/isotipoVerde.png" type="image/png" />
  </head>

  <body class="flex flex-col min-h-screen text-white relative bg-[#06000a]">
    <!-- Fondo adaptado del sitio principal, pero más oscuro para que resalte la data -->
    <div class="pointer-events-none fixed inset-0 -z-10" style="background-image: radial-gradient(circle at 50% -500px, #00ff7f 0%, transparent 70%), radial-gradient(circle at 80% 600px, rgba(0, 255, 127, 0.05) 0%, transparent 50%), linear-gradient(to bottom, #000000 0%, #0d0112 100%);"></div>

    <!-- Contenido principal -->
    <main class="flex-grow py-8 px-4 sm:px-6 md:px-8">
      <slot />
    </main>
    
  </body>
</html>
